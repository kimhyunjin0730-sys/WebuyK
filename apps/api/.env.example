DATABASE_URL="mysql://wbk:wbk@localhost:3306/wbk"
JWT_SECRET="dev-only-change-me"
PORT=4000
WEB_ORIGIN="http://localhost:3100"

# --- OAuth (optional) ---
# Leave any provider unset to disable its button on the web sign-in page.
#
# Google: https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI must exactly match GOOGLE_CALLBACK_URL below.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# Kakao: https://developers.kakao.com/console/app
#   Use the REST API key as KAKAO_CLIENT_ID. Client secret is optional
#   (enable in the console under Security → Client Secret).
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_CALLBACK_URL="http://localhost:4000/api/auth/kakao/callback"

# --- Portone (I'mport) ---
# Leave blank to use the in-memory MockGateway. Set both API key + secret to
# enable the live PortoneGateway. Get them from https://admin.portone.io
# (결제연동 → 식별코드 / API Keys).
PORTONE_IDENTIFICATION_CODE=""
PORTONE_API_KEY=""
PORTONE_API_SECRET=""
